{
  "name": "trader",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous trading runtime — India blocked-execution foundation",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node --experimental-specifier-resolution=node dist/main.js",
    "start:upstox:notifier": "tsx src/upstox/notifier-main.ts",
