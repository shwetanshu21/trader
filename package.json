{
  "name": "trader",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous trading runtime — India blocked-execution foundation",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node --experimental-specifier-resolution=node dist/main.js",
    "witness:capture": "node --import tsx src/deployment/witness-main.ts",
    "witness:capture:sh": "bash scripts/capture-cax11-witness.sh",
    "witness:steady": "node --import tsx src/deployment/witness-main.ts --steady-state",
    "witness:steady:long": "node --import tsx src/deployment/witness-main.ts --steady-state --steady-state-duration-sec 300",
    "witness:verify": "bash scripts/verify-m007-s01-witness.sh",
    "witness:all": "npx vitest run tests/deployment-witness-contract.test.ts tests/deployment-witness-capture.test.ts && bash scripts/verify-m007-s01-witness.sh",
    "proof:paper:s06": "node --import tsx src/deployment/verify-m009-s06-paper-proof.ts",
    "proof:paper:s06:sh": "bash scripts/verify-m009-s06-paper-proof.sh",
    "start:upstox:notifier": "tsx src/upstox/notifier-main.ts",
    "start:upstox:mcp-local": "tsx src/upstox/mcp-local-main.ts",
    "start:upstox:stack": "bash scripts/start-upstox-stack.sh",
    "verify:guidance": "python3 scripts/verify-m007-s03-guidance.py",
    "verify:upstox:bridge": "bash scripts/verify-upstox-bridge.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "select:winner": "bash scripts/walk-forward-select-winner.sh",
    "run:upstox": "bash scripts/walk-forward-run-upstox.sh",
    "select:winner:upstox": "bash scripts/walk-forward-select-winner-upstox.sh",
    "promote": "bash scripts/walk-forward-promote-upstox.sh",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "zod": "^3.24.2"
  }
}
