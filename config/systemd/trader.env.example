# Hetzner runtime defaults
NODE_ENV=production
TRADER_PORT=3001
TRADER_DB_PATH=./data/trader-upstox-static.db
TRADER_SCHEDULER_INTERVAL_MS=60000
TRADER_LOG_LEVEL=info
TRADER_MARKET_TIMEZONE=Asia/Kolkata
TRADER_EXECUTION_MODE=paper
TRADER_EXECUTION_OPERATOR_BIND_HOST=127.0.0.1

# Authenticated operator console
OPERATOR_UI_HOST=127.0.0.1
OPERATOR_UI_PORT=3100
OPERATOR_UI_DB_PATH=./data/trader-upstox-static.db
OPERATOR_UI_USERNAME=operator
# OPERATOR_UI_PASSWORD must be set in the real .env file.

# Upstox local sidecars
TRADER_UPSTOX_NOTIFIER_PORT=8788
TRADER_UPSTOX_MCP_LOCAL_PORT=8787
TRADER_UPSTOX_TOKEN_PATH=./tmp/upstox/notifier/latest-token.json
TRADER_UPSTOX_TOKEN_REFRESH_STATUS_PATH=./tmp/upstox/notifier/refresh-status.json
TRADER_UPSTOX_TOKEN_REFRESH_CHECK_INTERVAL_MS=3600000

# Upstox token request flow (used by manual UI trigger and automatic recovery)
# UPSTOX_CLIENT_ID=
# UPSTOX_CLIENT_SECRET=
# UPSTOX_NOTIFIER_URL=https://details.example.com/upstox/notifier

# Runtime should stay local-only behind Caddy.
# Caddy routes details.aeroinference.com -> 127.0.0.1:3100 for the operator console,
# keeps /upstox/* -> 127.0.0.1:8788 for the notifier, and leaves the runtime on loopback.
